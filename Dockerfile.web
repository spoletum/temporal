# Development image for PayR.Temporal.Web.
#
# Runs `dotnet watch` so file changes on the host (mounted into the container)
# trigger a rebuild + restart of the web UI automatically.

FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

# Restore dependencies first so they're cached across source changes.
# Copy all csprojs so project references and package references resolve.
COPY PayR.Temporal.slnx ./
COPY PayR.Temporal.SayHello.Client/PayR.Temporal.SayHello.Client.csproj ./PayR.Temporal.SayHello.Client/
COPY PayR.Temporal.Web/PayR.Temporal.Web.csproj ./PayR.Temporal.Web/
RUN dotnet restore ./PayR.Temporal.Web/PayR.Temporal.Web.csproj

# The rest of the source is bind-mounted at runtime (see podman-compose.yaml),
# so nothing else needs to be COPYed here for dev.

ENV DOTNET_USE_POLLING_FILE_WATCHER=1
ENV DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER=1
ENV DOTNET_WATCH_SUPPRESS_EMOJIS=1
ENV ASPNETCORE_ENVIRONMENT=Development

CMD ["dotnet", "watch", "--project", "PayR.Temporal.Web/PayR.Temporal.Web.csproj", "run", "--non-interactive", "--urls", "http://0.0.0.0:8080"]
