@page "/"
@inject IEnumerable<IWorkflowDefinition> Definitions

<PageTitle>Workflows · PayR.Temporal</PageTitle>

<h1>Workflows</h1>
<p class="text-muted">Start and observe Temporal workflows registered with this UI.</p>

@if (Definitions is null || !Definitions.Any())
{
    <div class="alert alert-warning">
        No workflow definitions are registered. Add one in
        <code>Program.cs</code> via
        <code>services.AddSingleton&lt;IWorkflowDefinition, YourDefinition&gt;()</code>.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var def in Definitions)
        {
            <a class="list-group-item list-group-item-action"
               href="@($"/workflows/{def.Id}")">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@def.DisplayName</h5>
                    <small class="text-muted">@def.WorkflowType</small>
                </div>
                <p class="mb-1 text-muted small">@def.Description</p>
            </a>
        }
    </div>
}
