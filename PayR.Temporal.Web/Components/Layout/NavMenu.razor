@inject IEnumerable<IWorkflowDefinition> Definitions
@inject IOptions<TemporalSettings> TemporalSettings

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PayR.Temporal</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (Definitions is not null)
        {
            <div class="nav-item px-3">
                <span class="nav-link text-uppercase fw-bold text-white-50 small">Workflows</span>
            </div>
            @foreach (var def in Definitions)
            {
                var href = $"/workflows/{def.Id}";
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="@href">
                        <span class="bi bi-play-circle-nav-menu" aria-hidden="true"></span> @def.DisplayName
                    </NavLink>
                </div>
            }
        }

        <div class="nav-item px-3 mt-2">
            <span class="nav-link text-uppercase fw-bold text-white-50 small">External</span>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link" href="@TemporalSettings.Value.UiUrl" target="_blank" rel="noopener noreferrer">
                <span class="bi bi-box-arrow-up-right-nav-menu" aria-hidden="true"></span> Temporal UI
            </a>
        </div>
    </nav>
</div>
