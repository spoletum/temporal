# Copy to .env and fill in real values before running:
#   cp compose/.env.example compose/.env

# --- SQL Server / Service Bus emulator --------------------------------------
# Accept the EULA for both SQL Server Linux and the Service Bus emulator.
#   Y = accept, N = reject (containers will not start if N)
# EULAs:
#   Service Bus emulator: https://github.com/Azure/azure-service-bus-emulator-installer/blob/main/EMULATOR_EULA.txt
#   SQL Server Linux:      https://go.microsoft.com/fwlink/?LinkId=746388
ACCEPT_EULA="N"

# Strong password required (>= 8 chars, upper/lower/digit/symbol per SQL policy).
MSSQL_SA_PASSWORD="ChangeMe!12345"

# Optional: seconds to wait for SQL Server before the emulator starts.
SQL_WAIT_INTERVAL=15

# --- Service Bus ports -------------------------------------------------------
SB_AMQP_PORT=5672
SB_HTTP_PORT=5300

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=payr
POSTGRES_PASSWORD=payr
POSTGRES_DB=payr
POSTGRES_PORT=5432

# --- Redis (Valkey) ----------------------------------------------------------
REDIS_PASSWORD=payr
REDIS_PORT=6379

# --- Temporal dev server -----------------------------------------------------
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233
TEMPORAL_UI_URL=http://localhost:8233

# --- PayR.Temporal.Web (Blazor UI) ------------------------------------------
WEB_PORT=8080
