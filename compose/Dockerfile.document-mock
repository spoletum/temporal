# Development image for the document validation mock service.

FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

COPY PayR.Temporal.slnx ./
COPY PayR.Temporal.Psp.TestData/PayR.Temporal.Psp.TestData.csproj ./PayR.Temporal.Psp.TestData/
COPY PayR.Temporal.Psp.DocumentValidationMock/PayR.Temporal.Psp.DocumentValidationMock.csproj ./PayR.Temporal.Psp.DocumentValidationMock/
RUN dotnet restore ./PayR.Temporal.Psp.DocumentValidationMock/PayR.Temporal.Psp.DocumentValidationMock.csproj

ENV DOTNET_USE_POLLING_FILE_WATCHER=1
ENV DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER=1
ENV DOTNET_WATCH_SUPPRESS_EMOJIS=1
ENV ASPNETCORE_ENVIRONMENT=Development

CMD ["dotnet", "watch", "--project", "PayR.Temporal.Psp.DocumentValidationMock/PayR.Temporal.Psp.DocumentValidationMock.csproj", "run", "--non-interactive", "--urls", "http://0.0.0.0:8080"]
